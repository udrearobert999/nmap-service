{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File",
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithCaller"
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./Logs/log_.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 10485760,
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} {ThreadId} [{Level}] (from {SourceContext}) {Exception} {Message}{NewLine}"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} {ThreadId} [{Level}] (from {SourceContext}) {Exception} {Message}{NewLine}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "<Database>"
  },
  "Kafka": {
    "BootstrapServers": "<Servers>",
    "ScanRequestsTopic": "<ScanRequestsTopic>",
    "ScanRequestsConsumerGroup": "<ScanRequestsConsumerGroup>",
    "ScanRequestsConcurrentMessagesLimit": 10,
    "ScanRequestsConcurrentConsumerLimit": 5
  },
  "Nmap": {
    "TimeoutSeconds": 180
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
